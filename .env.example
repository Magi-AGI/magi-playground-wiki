# MeTTa Playground sidecar — environment template.
# Copy to .env (gitignored) if you want to override defaults. All keys optional;
# the service ships with sane defaults from app/config.py.

# ── Sandbox runtime ──────────────────────────────────────────────────────────
# Container image used to evaluate user MeTTa code. Must already exist locally
# (built from runtime/Dockerfile via `docker build -t hyperon-runtime:0.2.10 runtime/`).
# MAGI_RUNTIME_IMAGE=hyperon-runtime:0.2.10

# Hard wall-clock budget per eval (seconds). Plan I-5 ceiling is 5s.
# MAGI_DEFAULT_TIMEOUT_S=5.0
# MAGI_MAX_TIMEOUT_S=10.0

# Docker resource caps.
# MAGI_MEMORY_LIMIT=256m
# MAGI_CPU_LIMIT=1.0
# MAGI_PIDS_LIMIT=64

# Path to docker binary (PATH lookup by default).
# MAGI_DOCKER_BIN=docker

# ── Concurrency / cleanup (2026-06-30 OOM incident hardening) ─────────────────
# Max simultaneous sandbox evals. Peak container memory ≈ this × MAGI_MEMORY_LIMIT,
# so keep it well under host RAM minus the wiki/OS. Default 4 (≈1GiB) is sized for
# the ~3.7GiB, no-swap EC2 host. Excess requests queue rather than over-commit RAM.
# MAGI_MAX_CONCURRENT_EVALS=4

# Stale-container sweep: service-labelled containers older than this TTL (seconds)
# are force-removed as a backstop for leaks from a crashed worker. MUST exceed
# MAGI_MAX_TIMEOUT_S so in-flight evals are never reaped — values at/below the
# eval window are auto-raised to a safe floor (max_timeout_s + 30s) at startup.
# MAGI_STALE_CONTAINER_TTL_S=300

# How often the background sweep runs (seconds); a sweep also runs once at startup.
# MAGI_CLEANUP_INTERVAL_S=60

# Per-call timeout for cleanup docker commands (rm/ps), seconds.
# MAGI_CLEANUP_OP_TIMEOUT_S=5.0

# ── Result cache (plan A-5) ──────────────────────────────────────────────────
# MAGI_RESULT_CACHE_SIZE=256
# MAGI_RESULT_CACHE_TTL_S=60
